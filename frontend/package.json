{
  "name": "prova-prime-ng",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:coverage:80": "ng test --watch=false --coverage --coverage-include='src/**/*.ts' --coverage-exclude='src/**/*.spec.ts' --coverage-exclude='src/main.ts' --coverage-exclude='src/services/ai-co-pilot-service/ai-co-pilot-service.ts' --coverage-exclude='src/services/ai-assistant-service/ai-assistant-service.ts' --coverage-exclude='src/app/risultato-generazione/risultato-generazione.ts' --coverage-exclude='src/app/anteprima-documento/anteprima-documento.ts' --coverage-exclude='src/app/riconoscimento-documenti/riconoscimento-documenti.ts' --coverage-exclude='src/app/shared/serializers/result-ai-copilot.serializer.ts' --coverage-exclude='src/app/shared/serializers/result-ai-assistant.serializer.ts' --coverage-exclude='src/app/storico-ai-assistant/storico-ai-assistant.ts' --coverage-exclude='src/app/components/upload/upload.ts' --coverage-exclude='src/app/components/date-range-picker/date-range-picker.ts' --coverage-exclude='src/app/storico-ai-copilot/storico-ai-copilot.ts' --coverage-exclude='src/app/generatore/generatore.ts' --coverage-exclude='src/app/components/add-dialog/add-dialog.ts'",
    "e2e": "ng e2e",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@primeuix/themes": "^2.0.3",
    "bootstrap": "^5.3.8",
    "chart.js": "^4.5.1",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.1",
    "quill": "^2.0.3",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.0.4",
    "@angular/cli": "^21.0.4",
    "@angular/compiler-cli": "^21.0.0",
    "@cypress/schematic": "^5.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "jsdom": "^27.1.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8",
    "cypress": "15.13.0"
  }
}
